# ========================================
# Ecomera Config Server Environment
# ========================================

# ---------------------------------------
# Server & Spring Configuration
# ---------------------------------------
SERVER_PORT=8888
SPRING_PROFILES_ACTIVE=native

# ---------------------------------------
# Eureka
# ---------------------------------------
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_SERVER_PORT=8761
EUREKA_HOSTNAME=localhost

# ---------------------------------------
# Service Ports (resolved by config server when serving config)
# ---------------------------------------
AUTH_SERVER_PORT=8081
PRODUCT_SERVER_PORT=8082
GATEWAY_SERVER_PORT=8080
CART_SERVER_PORT=8083

# ---------------------------------------
# Config Git (for native profile)
# ---------------------------------------
CONFIG_GIT_URI=https://github.com/ecomera-ecosystem/ecomera-config-server

# ---------------------------------------
# Vault
# ---------------------------------------
VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxxxxx
